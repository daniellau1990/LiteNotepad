{
  "name": "litnotepad",
  "version": "0.1.0",
  "description": "A lightweight cross-platform notepad replacement built with Tauri",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:win": "tauri build --target x86_64-pc-windows-msvc",
    "build:mac": "tauri build --target aarch64-apple-darwin",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "keywords": ["notepad", "text-editor", "tauri"],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.6"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.3"
  }
}
